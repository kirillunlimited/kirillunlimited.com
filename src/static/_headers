/assets/*
  Cache-Control: public, max-age=31536000, stale-while-revalidate=86400

/fonts/*
  Cache-Control: public, max-age=31536000

/favicon.ico
  Cache-Control: public, max-age=31536000

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate