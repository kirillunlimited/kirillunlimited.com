{% set pageTitle %}
  {% if title %}
    {{title}} – {{site.author}}
  {% else %}
    {{site.author}}
  {% endif %}
{% endset %}

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{description}}"/>
    <meta name="keywords" content="Kirill Ivanov, frontend, developer, engineer, javascript"/>
    <meta name="generator" content="Eleventy" >

    {# Open Graph #}
    <meta property="og:title" content="{{ pageTitle }}"/>
    <meta property="og:description" content="{{ description }}"/>
    <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
    <meta property="og:type" content="website" />

    {# Twitter #}
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta property="twitter:title" content="{{ pageTitle }}">
    <meta property="twitter:description" content="{{ description }}">

    {# Preload fonts #}
    <link rel="preload" href="/assets/fonts/GeistVariableVF.woff2" as="font" type="font/woff2" crossorigin>

    {# Styles #}
    <link rel="stylesheet" href="/assets/css/themes/light.css" media="(prefers-color-scheme: light)" data-color-scheme="light"/>
    <link rel="stylesheet" href="/assets/css/themes/dark.css" media="(prefers-color-scheme: dark)" data-color-scheme="dark"/>
    <link rel="stylesheet" href="/assets/css/index.css">

    {# Favicon #}
    <link rel="manifest" href="{{ '/manifest.webmanifest' | url }}">
    <link rel="icon" href="{{ '/favicon.ico' | url}}" sizes="any">
    <link rel="apple-touch-icon" href="{% imagePath 'src/assets/img/avatar.jpg', 'png', [192] %}">

    {# Theme #}
    <meta name="color-scheme" content="light dark">

    <script type="module" src="/assets/js/init.js"></script>
  </head>
  <body>
    {% include 'header.njk' %}
    <main class="main main--{{page.fileSlug}}">
      {{content | safe}}
    </main>
    {% include 'footer.njk' %}
    <script async type="module" src="/assets/js/app.js"></script>
    <script data-goatcounter="https://kirillunlimitedcom.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
  </body>
</html>